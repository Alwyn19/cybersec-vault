---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ContentCard from '../../components/ContentCard.astro';
import SearchBox from '../../components/SearchBox.astro';

const entries = (await getCollection('labs'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Security Labs | Kali Cyan Vault" description="Self-study labs, checklists, hints, and solutions focused on Web Security and AppSec.">
  <section class="page-hero compact">
    <p class="eyebrow">lab archive</p>
    <h1>Security Labs</h1>
    <p>Self-study labs, checklists, hints, and solutions focused on Web Security and AppSec.</p>
  </section>

  <SearchBox />

  <section class="content-section">
    <SectionHeader title="All entries" description="Search by title, tags, or description to quickly find relevant notes." />
    <div class="card-grid">
      {entries.map((entry) => <ContentCard entry={entry} collection="labs" />)}
    </div>
  </section>
</Layout>
