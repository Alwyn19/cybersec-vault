---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ContentCard from '../../components/ContentCard.astro';
import SearchBox from '../../components/SearchBox.astro';

const entries = (await getCollection('labs'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Security Labs | Kali Cyan Vault" description="Lab tự học, checklist, hint và solution cho các chủ đề Web/AppSec.">
  <section class="page-hero compact">
    <p class="eyebrow">lab archive</p>
    <h1>Security Labs</h1>
    <p>Lab tự học, checklist, hint và solution cho các chủ đề Web/AppSec.</p>
  </section>

  <SearchBox />

  <section class="content-section">
    <SectionHeader title="All entries" description="Dùng ô search để lọc theo tiêu đề, tag hoặc mô tả." />
    <div class="card-grid">
      {entries.map((entry) => <ContentCard entry={entry} collection="labs" />)}
    </div>
  </section>
</Layout>
