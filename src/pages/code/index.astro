---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ContentCard from '../../components/ContentCard.astro';
import SearchBox from '../../components/SearchBox.astro';

const entries = (await getCollection('code'))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Code Vault | Kali Cyan Vault" description="Snippet, payload, command, checklist và script phục vụ CTF/lab hợp pháp.">
  <section class="page-hero compact">
    <p class="eyebrow">code archive</p>
    <h1>Code Vault</h1>
    <p>Snippet, payload, command, checklist và script phục vụ CTF/lab hợp pháp.</p>
  </section>

  <SearchBox />

  <section class="content-section">
    <SectionHeader title="All entries" description="Dùng ô search để lọc theo tiêu đề, tag hoặc mô tả." />
    <div class="card-grid">
      {entries.map((entry) => <ContentCard entry={entry} collection="code" />)}
    </div>
  </section>
</Layout>
