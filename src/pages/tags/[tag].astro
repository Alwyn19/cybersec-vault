---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BaseLayout.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import ContentCard from '../../components/ContentCard.astro';

export async function getStaticPaths() {
  const collections = ['writeups', 'labs', 'code'] as const;
  const allEntries: any[] = [];

  for (const collection of collections) {
    const entries = await getCollection(collection);

    for (const entry of entries) {
      if (entry.data.draft) continue;

      const tags = entry.data.tags ?? [];

      for (const tag of tags) {
        allEntries.push({
          tag,
          entry,
          collection
        });
      }
    }
  }

  const tags = [...new Set(allEntries.map((item) => item.tag))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      entries: allEntries.filter((item) => item.tag === tag)
    }
  }));
}

const { tag, entries } = Astro.props;
---

<Layout title={`#${tag} | CyberSec Vault`} description={`Entries tagged with ${tag}`}>
  <section class="page-hero compact">
    <p class="eyebrow">tag filter</p>
    <h1>#{tag}</h1>
    <p>Các nội dung trong vault có cùng tag.</p>
  </section>

  <section class="content-section">
    <SectionHeader title="Tagged entries" description={`${entries.length} result(s) found.`} />

    <div class="card-grid">
      {entries.map(({ entry, collection }) => (
        <ContentCard entry={entry} collection={collection} />
      ))}
    </div>
  </section>
</Layout>
