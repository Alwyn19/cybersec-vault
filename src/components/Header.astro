---
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const currentPath = Astro.url.pathname;

const links = [
  { href: base, label: 'Home' },
  { href: `${base}writeups/`, label: 'Write-ups' },
  { href: `${base}labs/`, label: 'Labs' },
];

function isActive(href: string) {
  if (href === base) return currentPath === base;
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <a class="brand" href={base} aria-label="Kali Cyan Vault home">
    <img class="brand-logo" src={`${base}images/logo.png`} alt="Alwyn logo" />
    <span class="brand-text"><strong>Alwyn</strong> CyberSec</span>
  </a>
  <nav class="nav-links" aria-label="Primary navigation">
    {links.map((link) => (
      <a href={link.href} class:list={[isActive(link.href) && 'active']}>{link.label}</a>
    ))}
  </nav>
</header>
